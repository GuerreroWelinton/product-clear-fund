# Normalize line endings to LF in the repository and on checkout.
# Prevents CRLF/LF churn between Windows, macOS and Linux contributors.
* text=auto eol=lf

# Binary assets Git must never try to normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.woff binary
*.woff2 binary
*.pdf binary
